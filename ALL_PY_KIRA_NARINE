class Add_order(QtWidgets.QDialog, Ui_Dialog_Order):
    def __init__(self, order_win, main_win):
        super().__init__()
        self.setupUi(self)
        self.db = Databaser()
        self.order_win = order_win
        self.main_win = main_win
        self.dateEdit.setDate(QDate.currentDate())
        self.pushButton.hide()
        self.pushButton_2.hide()
        self.pushButton_4.clicked.connect(self.close)
        self.pushButton_3.clicked.connect(self.add_order)
        for i in self.db.select_status():
            self.comboBox.addItem(str(i[1]), i[0])

    def add_order(self):
        try:
            pickup_point = self.lineEdit.text()
            issue_date = self.dateEdit.date().toPyDate()
            id_user = self.main_win.user
            self.db.add_card_order(pickup_point, issue_date, id_user)
            self.order_win.delete_order()
            self.order_win.insert_data_order()
            QtWidgets.QMessageBox.information(
                self,
                "Уведомление",
                "Вы успешно добавили заказ"
            )
            self.close()

        except Exception as e:
            print(e)
