from autorization_form import*
from db import *
from main import*
class Login(QtWidgets.QMainWindow,Ui_MainWindow_auto):
    def __init__(self):
        super().__init__()
        self.setupUi(self)
        self.db= Databaser()
        self.pushButton.clicked.connect(self.autoriz)
        self.pushButton_2.clicked.connect(self.guest)
    def autoriz(self):
        try:
            login = self.lineEdit.text()
            password = self.lineEdit_2.text()
            if login == "" or password == "":
                return QtWidgets.QMessageBox.critical(self, 'Ошибка', 'Пожалуйста, заполните все поля!')
            result= self.db.auto(login,password)
            if result is None:
                return QtWidgets.QMessageBox.critical(self,'Ошибка','Неверный логин или пароль!\nПожалуйста, проверьте введённые данные.')
            role, user, fio=result
            if role ==1:
                self.entrance(role,user,fio)
                QtWidgets.QMessageBox.information(self,'Уведомление',f'Здравствуйте, Администратор {fio}!')
            if role ==2:
                self.entrance(role, user, fio)
                QtWidgets.QMessageBox.information(self, 'Уведомление', f'Здравствуйте, Клиент {fio}!')
            if role ==3:
                self.entrance(role, user, fio)
                QtWidgets.QMessageBox.information(self,'Уведомление',f'Здравствуйте, Менеджер {fio}!')

        except Exception as e:
            print(e,'autoriz')

    def entrance(self,role,user,fio):
        self.window=Main_window(role,user,fio)
        self.window.show()
        self.close()
    def guest(self):
        self.window = Main_window(4,0,'Гостевой режим')
        self.window.show()
        self.close()
