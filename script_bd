create database Stationery;
use Stationery;
create table role(
id_role int primary key auto_increment,
name_role varchar(50));

create table status(
id_status int primary key auto_increment,
name_status varchar(50));

create table category(
id_category int primary key auto_increment,
name_category varchar(50));

create table manufacturer(
id_manufacturer int primary key auto_increment,
name_manufacturer varchar(50),
country varchar(50)
);
create table supplier(
id_supplier int primary key auto_increment,
name_supplier varchar(50),
phone varchar(15),
email varchar(150)
);

create table product(
id_product int primary key auto_increment,
article varchar(150),
product_name varchar(150),
description varchar(150),
id_category int,
id_manufacturer int,
id_supplier int,
price decimal(10,2),
unit enum('шт','пачка','набор'),
stock_quantity int(10),
discount_percent int(10),
image_path varchar(150),
foreign key(id_category) references category(id_category),
foreign key(id_manufacturer) references manufacturer(id_manufacturer),
foreign key(id_supplier) references supplier(id_supplier)

);

create table user(
id_user int primary key auto_increment,
fio_user varchar(150),
login varchar(150),
password varchar(150),
id_role int,
foreign key(id_role) references role(id_role)
);

create table orders(
id_order int primary key auto_increment,
pickup_point varchar(150),
order_date date,
issue_date date,
id_user int,
id_status int,
foreign key(id_user) references user(id_user),
foreign key(id_status) references status(id_status)

);


create table order_item(
id_order_item int primary key auto_increment,
id_order int,
id_product int,
id_quantity int,
pickup_point decimal(10,2),
foreign key(id_order) references orders(id_order),
foreign key(id_product) references product(id_product)

);
