    def update_card_product(self,product_name,description,id_category,id_manufacturer,id_supplier,price,unit,stock_quantity,discount_percent,image_path,id_product):
        sql='''
        
        UPDATE product
        SET `product_name` = %s,
         `description` = %s,
          `id_category` = %s, 
          `id_manufacturer` = %s, 
          `id_supplier` = %s,
           `price` = %s, 
           `unit` = %s,
            `stock_quantity` = %s, 
            `discount_percent` = %s, 
            `image_path` = %s
            WHERE `id_product` = %s;

        
        
        '''
        self.cursor.execute(sql,(product_name,description,id_category,id_manufacturer,id_supplier,price,unit,stock_quantity,discount_percent,image_path,id_product))

    def delete_card_product(self,id_product):
