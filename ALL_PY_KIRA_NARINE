                QtWidgets.QMessageBox.information(self,'Уведомление',f'Здравствуйте, Администратор {fio}!')
            if role ==2:
                self.entrance(role, user, fio)
                QtWidgets.QMessageBox.information(self, 'Уведомление', f'Здравствуйте, Клиент {fio}!')
            if role ==3:
                self.entrance(role, user, fio)
                QtWidgets.QMessageBox.information(self,'Уведомление',f'Здравствуйте, Менеджер {fio}!')

        except Exception as e:
            print(e,'autoriz')

    def entrance(self,role,user,fio):
        self.window=Main_window(role,user,fio)
        self.window.show()
