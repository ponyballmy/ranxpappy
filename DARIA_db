    def db_filter_search(self,line,supp,change_price):
        try:
            pattern = f"%{line}%"
            params = [pattern,pattern,pattern,pattern,pattern]
            sql = """
                  select p.id_product, \
                         p.product_name, \
                         p.description, \
                         c.name_category, \
                         m.name_manufacturer,
                         s.name_supplier, \
                         p.price, \
                         p.unit, \
                         p.stock_quantity, \
                         p.discount_percent, \
                         p.image_path
                  from product p
                           join category c on p.id_category = c.id_category
                           join manufacturer m on p.id_manufacturer = m.id_manufacturer
                           join supplier s on p.id_supplier = s.id_supplier \
                  where (p.product_name like %s or p.description like %s or c.name_category like %s or m.name_manufacturer like %s or s.name_supplier like %s)
