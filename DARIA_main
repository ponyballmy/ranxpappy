class OrderEdit(QtWidgets.QDialog, Ui_Dialog):
    def __init__(self, data_item,order_win):
        try:
            super().__init__()
            self.setupUi(self)
            self.db = Databaser()
            self.order_win = order_win
            self.data_item = data_item

            self.labelARTICUL.setText(str(data_item[0]))
            self.lineEditPoint.setText(data_item[1])
            self.dateEditDatedelivery.setDate(data_item[3])

            for i in self.db.all_status():
                self.comboBoxStatus.addItem(str(i[1]), i[0])
            self.comboBoxStatus.setCurrentText(data_item[5])

            self.pushButtonAdd.hide()
            self.pushButton_close.clicked.connect(self.close)
            self.pushButtonsave.clicked.connect(self.save_edit_order)
            self.pushButton_del.clicked.connect(self.delete_order)
        except Exception as e:
            print(e, '__init__ card order')

    #сохранение отредактированного заказа
    def save_edit_order(self):
        try:
            self.db.update_orders(self.labelARTICUL.text(), self.lineEditPoint.text(), self.dateEditDatedelivery.date().toPyDate(), self.comboBoxStatus.currentData())
            self.order_win.clean_scroll_order()
            self.order_win.insert_scroll_order()
            QtWidgets.QMessageBox.information(self, 'Успешно', 'Заказ изменен')
            self.close()
        except Exception as e:
            print(e, 'save_edit_order')

    def delete_order(self):
        try:
            messages = QtWidgets.QMessageBox(self)
            messages.setWindowTitle('Подтверждение')
            messages.setText('Удалить товар?')
            btn_yes = messages.addButton('Да', QtWidgets.QMessageBox.ButtonRole.YesRole)
            btn_no = messages.addButton('Нет', QtWidgets.QMessageBox.ButtonRole.NoRole)
            messages.exec()
            if messages.clickedButton() == btn_no:
                return
            self.db.drop_order(self.data_item[0])
            self.order_win.clean_scroll_order()
            self.order_win.insert_scroll_order()
            QtWidgets.QMessageBox.information(self, "Успешное удаление заказа", f"Заказ удален: {self.data_item[0]}")
            self.close()
        except Exception as e:
            if e.args[0] == 1451:
                QtWidgets.QMessageBox.warning(self, "Ошибка", "Заказ невозможно удалить")
            else:
                print(e, 'delete_order')

