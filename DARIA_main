class OrderWin(QtWidgets.QMainWindow,Ui_OrderWin):
    def __init__(self, main_win):
        try:
            super().__init__()
            self.setupUi(self)
            self.db = Databaser()
            self.main_win = main_win

            self.labelFIO.setText(self.main_win.fio)
            self.layout_order = QVBoxLayout()
            self.scrollAreaWidgetContents.setLayout(self.layout_order)

            if self.main_win.role==3:
                self.pushButtonAddOrder.hide()
                self.label.hide()

            self.insert_scroll_order()
            self.pushButtonReturn.clicked.connect(self.return_main)
            self.pushButtonAddOrder.clicked.connect(self.open_add_dialog)
        except Exception as e:
            print(e, '__init__ win order')

    def insert_scroll_order(self):
        try:
            data = self.db.data_card_order()
            for i in data:
                card = OrderCard(i, self, self.main_win)
                self.layout_order.addWidget(card)
        except Exception as e:
            print(e,'insert_scroll_order')

    def clean_scroll_order(self):
        try:
            while self.layout_order.count():
                item = self.layout_order.takeAt(0)
                if item.widget():
                    item.widget().deleteLater()
        except Exception as e:
            print(e,'clean_scroll_order')

    # возврат на главное окно
    def return_main(self):
        try:
            self.win = MainWin(self.main_win.role, self.main_win.fio, self.main_win.id_user)
            self.win.show()
            self.close()
        except Exception as e:
            print(e,'return_main')

    def open_add_dialog(self):
        try:
            self.win = OrderAdd(self)
            self.win.show()
        except Exception as e:
            print(e,'open_add_dialog')

