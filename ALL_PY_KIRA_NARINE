import pymysql


class Databaser:
    def __init__(self):
        con = pymysql.connect(host="localhost", user="root", password="password", db="stationery", autocommit=True)
        self.cursor = con.cursor()

    def auto(self, login, password):
        sql = '''
        select id_role,id_user,fio_user from user where login=%s and password=%s

        '''
        self.cursor.execute(sql, (login, password))
        res = self.cursor.fetchone()
        return res

    def insert_data_card_product(self):
        sql = '''
        select product.id_product,product.product_name,product.description,category.name_category,manufacturer.name_manufacturer,
        supplier.name_supplier,product.price,product.unit,product.stock_quantity,product.discount_percent,product.image_path
        from product 
        join category on category.id_category=product.id_category
        join manufacturer on manufacturer.id_manufacturer=product.id_manufacturer
        join supplier on supplier.id_supplier=product.id_supplier


        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

    def select_suiplier(self):
        sql = '''

        select id_supplier,name_supplier from supplier

        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

    def select_manufacturer(self):
        sql = '''

        select id_manufacturer,name_manufacturer from manufacturer

        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

    def select_category(self):
        sql = '''

        select id_category,name_category from category

        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

    def select_status(self):
        sql = '''

        select id_status,name_status from status

        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

    def search_filter(self, text, suplier, price):
        pattern = f"%{text}%"
        parametrs = [pattern, pattern, pattern, pattern]

        sql = '''

        select product.id_product,product.product_name,product.product_name,category.name_category,manufacturer.name_manufacturer,
        supplier.name_supplier,product.price,product.unit,product.stock_quantity,product.discount_percent,product.image_path
        from product 
        join category on category.id_category=product.id_category
        join manufacturer on manufacturer.id_manufacturer=product.id_manufacturer
        join supplier on supplier.id_supplier=product.id_supplier
        where(product.product_name like %s or product.product_name like %s or category.name_category like %s or manufacturer.name_manufacturer like %s)

        '''

        if suplier != 0:
            sql += " and supplier.id_supplier=%s"
            parametrs.append(suplier)

        """if sale=='По возрастанию скидки':
            sql+=' order by product.discount_percent asc'

        if sale =='По убыванию скидки':
            sql+=' order by product.discount_percent desc'"""

        """ if discount_percent=='Скидка от 0-11%':
                   sql+=" and product.discount_percent between 0 and 11"

               if discount_percent == 'Скидка от 11-18%':
                   sql += " and product.discount_percent between 11 and 18"

               if discount_percent == 'Скидка от 19% и более':
                   sql += " and product.discount_percent >= 19"
                   """

        if price == 'По возрастанию цены':
            sql += ' order by product.price asc'

        if price == 'По убыванию цены':
            sql += ' order by product.price desc'

        self.cursor.execute(sql, tuple(parametrs))
        res = self.cursor.fetchall()
        return res

    def update_card_product(self, product_name, description, id_category, id_manufacturer, id_supplier, price, unit,
                            stock_quantity, discount_percent, image_path, id_product):
        sql = '''

        UPDATE product
        SET `product_name` = %s,
         `description` = %s,
          `id_category` = %s, 
          `id_manufacturer` = %s, 
          `id_supplier` = %s,
           `price` = %s, 
           `unit` = %s,
            `stock_quantity` = %s, 
            `discount_percent` = %s, 
            `image_path` = %s
            WHERE `id_product` = %s;



        '''
        self.cursor.execute(sql, (product_name, description, id_category, id_manufacturer, id_supplier, price, unit,
                                  stock_quantity, discount_percent, image_path, id_product))

    def delete_card_product(self, id_product):
        sql = '''
        DELETE FROM product WHERE id_product =%s
        '''
        self.cursor.execute(sql, (id_product,))

    def add_card_product(self, product_name, description, id_category, id_manufacturer, id_supplier, price, unit,
                         stock_quantity, discount_percent, image_path):
        sql = '''
        INSERT INTO product (`product_name`, `description`, `id_category`, `id_manufacturer`, `id_supplier`, `price`, `unit`, `stock_quantity`, `discount_percent`, `image_path`)
         VALUES (%s, %s,%s, %s, %s, %s, %s,%s, %s, %s);

        '''
        self.cursor.execute(sql, (product_name, description, id_category, id_manufacturer, id_supplier, price, unit,
                                  stock_quantity, discount_percent, image_path))

    def update_card_order(self, pickup_point, issue_date, id_status, id_order):
        sql = '''
        UPDATE orders SET 
        `pickup_point` = %s,
         `issue_date` = %s, 
         `id_status`=%s
          WHERE id_order=%s 


        '''
        self.cursor.execute(sql, (pickup_point, issue_date, id_status, id_order))

    def delete_card_order(self, id_order):

        sql = '''
        DELETE FROM orders WHERE id_order = %s

        '''
        self.cursor.execute(sql, (id_order,))

    def add_card_order(self, pickup_point, issue_date, id_user):
        sql = '''
        INSERT INTO orders (`pickup_point`, `order_date`, `issue_date`, `id_user`, `id_status`) 
        VALUES (%s, NOW(), %s, %s, 1);


        '''
        self.cursor.execute(sql, (pickup_point, issue_date, id_user))

    def insert_data_order_card(self):
        sql = '''

        select orders.id_order,orders.pickup_point,orders.order_date,orders.issue_date,status.name_status
        from orders
        join status on orders.id_status = status.id_status

        '''
        self.cursor.execute(sql)
        res = self.cursor.fetchall()
        return res

